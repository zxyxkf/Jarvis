# Environment variables (copy to .env and fill in values)
# Never commit .env to version control

# === Database ===
DATABASE_URL=postgresql://jarvis:jarvis_password@localhost:5432/jarvis
DB_PASSWORD=jarvis_password

# === Redis ===
REDIS_URL=redis://localhost:6379

# === MinIO (Object Storage) ===
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=jarvis
MINIO_ROOT_PASSWORD=jarvis_minio_password

# === JWT ===
JWT_ACCESS_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === LLM API Keys ===
DEEPSEEK_API_KEY=your-deepseek-api-key
QWEN_API_KEY=your-qwen-api-key
OPENAI_API_KEY=your-openai-api-key

# === Embedding & Reranker ===
EMBEDDING_API_URL=https://api.deepseek.com/v1
EMBEDDING_MODEL=text-embedding-3-small
RERANKER_API_URL=https://api.deepseek.com/v1

# === App ===
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
